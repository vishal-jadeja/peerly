{
  "permissions": {
    "allow": [
      "Bash(npm install *)",
      "Bash(npm run *)",
      "WebFetch(domain:api.anthropic.com)",
      "Bash(python3 *)",
      "Bash(npx tsc *)",
      "Bash(git *)",
      "Bash(where psql *)",
      "Bash(where pg_isready)",
      "Bash(curl -s -o /dev/null -w \"HTTP %{http_code} | %{size_download}b | redirect: %{redirect_url}\\\\n\" http://localhost:3000/)",
      "Bash(curl -s -o /dev/null -w \"HTTP %{http_code} | %{size_download}b\\\\n\" http://localhost:3000/login)",
      "Bash(curl -s -o /dev/null -w \"HTTP %{http_code} | %{size_download}b\\\\n\" http://localhost:3000/register)",
      "Bash(curl -s -o /dev/null -w \"HTTP %{http_code} | redirect: %{redirect_url}\\\\n\" -L --max-redirs 0 http://localhost:3000/dashboard)",
      "Bash(curl -s -X POST http://localhost:3000/api/auth/register -H \"Content-Type: application/json\" -d '{\"email\":\"test@example.com\",\"password\":\"password123\"}' -w \"\\\\nHTTP %{http_code}\\\\n\")"
    ]
  }
}
